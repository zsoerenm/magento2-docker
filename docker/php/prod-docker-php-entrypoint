#!/bin/sh
set -ex

# Always restore config.php from the image. The app/etc/ directory is a
# Docker volume so env.php persists across deploys, but config.php must
# come from the image (it's committed to git and changes with each deploy).
cp /usr/local/share/magento-config.php app/etc/config.php

# Remove the ready file so healthcheck fails until setup is complete
rm -f /tmp/magento-ready

# Signal to base entrypoint that production handles setup:upgrade separately
export MAGENTO_PRODUCTION_ENTRYPOINT=1

# Run the base entrypoint (handles setup:install on fresh or setup:config:set
# on existing installs — picks up env var changes like BASE_URL, DB credentials)
/usr/local/bin/base-docker-php-entrypoint

if [ ! -z "$DB_HOST" ]; then
    # Adobe pipeline deployment: di:compile and static-content:deploy are done
    # at build time in the Dockerfile. At runtime we only run setup:upgrade
    # with --keep-generated to preserve the compiled code from the build stage.
    php bin/magento setup:upgrade --keep-generated
    php bin/magento app:config:import 2>/dev/null || true

    # Resolve MAGENTO_THEME to a numeric theme_id now that the DB is ready.
    # Writes to both core_config_data (for cron/CLI processes) and exports as
    # CONFIG__DEFAULT__DESIGN__THEME__THEME_ID (for this PHP-FPM process).
    # Must happen after setup:upgrade (which creates the theme table).
    if [ ! -z "$MAGENTO_THEME" ] && [ -e app/etc/env.php ]; then
        THEME_ID=$(php -r "
            \$env = include 'app/etc/env.php';
            \$db = \$env['db']['connection']['default'] ?? null;
            if (!\$db) exit(0);
            try {
                \$pdo = new PDO(\"mysql:host={\$db['host']};dbname={\$db['dbname']}\", \$db['username'], \$db['password']);
                \$stmt = \$pdo->prepare('SELECT theme_id FROM theme WHERE theme_path = ? AND area = \"frontend\" LIMIT 1');
                \$stmt->execute([getenv('MAGENTO_THEME')]);
                \$id = \$stmt->fetchColumn();
                if (\$id) {
                    // Write to DB so cron and other CLI processes see it too
                    \$pdo->prepare('INSERT INTO core_config_data (scope, scope_id, path, value) VALUES (\"default\", 0, \"design/theme/theme_id\", ?) ON DUPLICATE KEY UPDATE value = ?')
                         ->execute([\$id, \$id]);
                    echo \$id;
                }
            } catch (Exception \$e) {}
        " 2>/dev/null || true)
        if [ ! -z "$THEME_ID" ]; then
            export CONFIG__DEFAULT__DESIGN__THEME__THEME_ID="$THEME_ID"
            echo "🎨 Theme '${MAGENTO_THEME}' resolved to ID ${THEME_ID}"
        fi
    fi

    php bin/magento cache:flush
fi

# Signal that setup is complete and php-fpm can serve requests
touch /tmp/magento-ready

exec "$@"
