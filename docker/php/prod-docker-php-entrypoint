#!/bin/sh
set -ex

# Signal to base entrypoint that production handles its own setup
export MAGENTO_PRODUCTION_ENTRYPOINT=1

# Run the base entrypoint (handles setup:install or setup:config:set)
/usr/local/bin/base-docker-php-entrypoint

# Remove the ready file so healthcheck fails until setup is complete
rm -f /tmp/magento-ready

if [ ! -z "$DB_HOST" ]; then
    # Clear generated code and rebuild the autoloader. The Docker image
    # contains compiled Proxy/Interceptor classes and a classmap pointing
    # to them from the build stage. We must remove those files AND update
    # the classmap, otherwise PHP fatals during Magento bootstrap.
    rm -rf generated/code
    mkdir -p generated/code
    composer dump-autoload

    # Standard Magento deployment sequence (Adobe docs):
    # https://experienceleague.adobe.com/docs/commerce-operations/configuration-guide/deployment/technical-details.html
    php bin/magento setup:upgrade
    php bin/magento app:config:import 2>/dev/null || true
    php bin/magento setup:di:compile
    php bin/magento setup:static-content:deploy -f
    php bin/magento cache:flush
fi

# Signal that setup is complete and php-fpm can serve requests
touch /tmp/magento-ready

exec "$@"
