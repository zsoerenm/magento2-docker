#!/bin/sh
set -ex

# Always restore config.php from the image. The app/etc/ directory is a
# Docker volume so env.php persists across deploys, but config.php must
# come from the image (it's committed to git and changes with each deploy).
cp /usr/local/share/magento-config.php app/etc/config.php

# Remove the ready file so healthcheck fails until setup is complete
rm -f /tmp/magento-ready

# Clear generated code and rebuild the autoloader BEFORE any bin/magento call.
# The Docker image contains compiled Proxy/Interceptor classes from the build
# stage. These must be removed so the autoloader doesn't fatal on stale classes.
rm -rf generated/code
mkdir -p generated/code
composer dump-autoload

# Signal to base entrypoint that production handles setup:upgrade separately
export MAGENTO_PRODUCTION_ENTRYPOINT=1

# Run the base entrypoint (handles setup:install on fresh or setup:config:set
# on existing installs — picks up env var changes like BASE_URL, DB credentials)
/usr/local/bin/base-docker-php-entrypoint

if [ ! -z "$DB_HOST" ]; then
    # Standard Magento deployment sequence (Adobe docs):
    # https://experienceleague.adobe.com/docs/commerce-operations/configuration-guide/deployment/technical-details.html
    php bin/magento setup:upgrade
    php bin/magento app:config:import 2>/dev/null || true
    php bin/magento setup:di:compile
    php bin/magento setup:static-content:deploy -f

    # Set base URL AFTER all compilation steps, then flush caches.
    # config:set is the LAST Magento CLI call — cache:flush after it
    # ensures the config cache is rebuilt correctly on the first FPM request.
    if [ ! -z "$BASE_URL" ]; then
        php bin/magento config:set web/unsecure/base_url "$BASE_URL"
        php bin/magento config:set web/secure/base_url "$BASE_URL"
    fi
    php bin/magento cache:flush
fi

# Signal that setup is complete and php-fpm can serve requests
touch /tmp/magento-ready

exec "$@"
