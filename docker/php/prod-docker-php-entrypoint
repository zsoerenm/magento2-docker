#!/bin/sh
set -e

# Signal to base entrypoint that production handles its own setup:upgrade
export MAGENTO_PRODUCTION_ENTRYPOINT=1

# Run the base entrypoint (handles setup:install or setup:config:set)
/usr/local/bin/base-docker-php-entrypoint

if [ ! -z "$DB_HOST" ]; then
    # Enable maintenance mode by touching the flag file directly.
    # We can't use `php bin/magento maintenance:enable` because generated/code
    # may be corrupted or missing, and any bin/magento call will fail.
    touch var/maintenance.flag

    # Clear generated code — may be corrupted by a previous failed run
    # or stale from the build stage after setup:install ran
    rm -rf generated/code/*

    # setup:upgrade regenerates generated/code as needed
    php bin/magento setup:upgrade
    php bin/magento app:config:import 2>/dev/null || true
    php bin/magento setup:di:compile
    php bin/magento cache:flush

    rm -f var/maintenance.flag
fi

# Signal that setup is complete and php-fpm can serve requests
touch /tmp/magento-ready

"$@"
