#!/bin/sh
set -ex

# Go through the list of possible arguments and check if a corresponding
# environment variable exists. If yes add it to the list of arguments, that
# is going to be used for `setup:install` or `setup:config:set`.
# `setup:install` will be used if the file `app/etc/env.php` doesn't exist.
# Here an example:
# For the argument `--db-host` the environment variable `DB_HOST` is checked.

magento_help=$(if [ -e app/etc/env.php ]; then \
    php bin/magento setup:config:set --help
else \
    php bin/magento setup:install --help
fi)

args=""

while read line 
do
    env_ref=$(echo $line | awk -v FS="(--|=)" '{print $2}' | awk '{ print toupper($0) }' | tr '-' '_')
    env_var=$(eval echo \$$env_ref)
    arg=$(echo $line | awk -F= '{print $1}')
    
    # Check if argument ends with "password" and look for corresponding _FILE env var
    if [[ "$arg" == *"password"* ]]; then
        env_file_ref="${env_ref}_FILE"
        env_file_path=$(eval echo \$$env_file_ref)
        if [[ ! -z "$env_file_path" && -f "$env_file_path" ]]; then
            env_var=$(cat "$env_file_path")
        fi
    fi
    
    [[ ! -z "$env_var" ]] && args="${args} $arg=${env_var}"
done < <(echo "$magento_help" | sed 's/^[ \t]*//' | tr -d '[' | grep -- "^--.*=")

if [ -e app/etc/env.php ]
then
    php bin/magento setup:config:set ${args}

    # Run database migrations if needed (e.g. after Magento version upgrade)
    if ! php bin/magento setup:db:status > /dev/null 2>&1; then
        echo "⚙️  Database schema is outdated — running setup:upgrade..."
        php bin/magento setup:upgrade
        php bin/magento cache:flush
        echo "✅ Database upgrade complete"
    fi
else
    php bin/magento setup:install ${args}
fi

# Auto-detect Hyvä theme and configure accordingly
# Hyvä uses Tailwind CSS + Alpine.js — Magento's built-in JS/CSS bundling conflicts with it
if php bin/magento module:status 2>/dev/null | grep -q "Hyva_Theme"; then
    echo "🎨 Hyvä theme detected — disabling legacy JS/CSS bundling"
    # Set via env vars so Magento picks them up at runtime (no DB write needed)
    # Only set if not already defined, so users can override
    export CONFIG__DEFAULT__DEV__JS__MERGE_FILES="${CONFIG__DEFAULT__DEV__JS__MERGE_FILES:-0}"
    export CONFIG__DEFAULT__DEV__JS__ENABLE_JS_BUNDLING="${CONFIG__DEFAULT__DEV__JS__ENABLE_JS_BUNDLING:-0}"
    export CONFIG__DEFAULT__DEV__JS__MINIFY_FILES="${CONFIG__DEFAULT__DEV__JS__MINIFY_FILES:-0}"
    export CONFIG__DEFAULT__DEV__JS__MOVE_SCRIPT_TO_BOTTOM="${CONFIG__DEFAULT__DEV__JS__MOVE_SCRIPT_TO_BOTTOM:-0}"
    export CONFIG__DEFAULT__DEV__CSS__MERGE_CSS_FILES="${CONFIG__DEFAULT__DEV__CSS__MERGE_CSS_FILES:-0}"
    export CONFIG__DEFAULT__DEV__CSS__MINIFY_FILES="${CONFIG__DEFAULT__DEV__CSS__MINIFY_FILES:-0}"
    export CONFIG__DEFAULT__DEV__TEMPLATE__MINIFY_HTML="${CONFIG__DEFAULT__DEV__TEMPLATE__MINIFY_HTML:-0}"
    export CONFIG__DEFAULT__CUSTOMER__CAPTCHA__ENABLE="${CONFIG__DEFAULT__CUSTOMER__CAPTCHA__ENABLE:-0}"

    # Auto-start Tailwind watcher in the background (dev only)
    deploy_mode=$(php bin/magento deploy:mode:show 2>/dev/null | grep -o "developer\|production" || echo "unknown")
    if [ "$deploy_mode" = "developer" ] && command -v tailwind > /dev/null 2>&1; then
        echo "👀 Starting Tailwind watcher in background..."
        tailwind watch &
    fi
fi

smtp_password="$CONFIG__DEFAULT__SYSTEM__SMTP__PASSWORD_UNENCRYPTED"
if [[ ! -z "$CONFIG__DEFAULT__SYSTEM__SMTP__PASSWORD_UNENCRYPTED_FILE" && -f "$CONFIG__DEFAULT__SYSTEM__SMTP__PASSWORD_UNENCRYPTED_FILE" ]]; then
    smtp_password=$(cat "$CONFIG__DEFAULT__SYSTEM__SMTP__PASSWORD_UNENCRYPTED_FILE")
fi

if [ ! -z "$smtp_password" ]; then
    php bin/magento config:set system/smtp/password ${smtp_password}
fi

"$@"
